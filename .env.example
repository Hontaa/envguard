# Copy to .env and fill in. NEVER commit the real .env (it is gitignored).

# Pre-issued API keys (comma-separated). Optional — keys are also minted via checkout.
ENVGUARD_KEYS=sk_demo_123

# SQLite drift DB path
ENVGUARD_DB=envguard.db

# --- Lemon Squeezy billing (get from lemonsqueezy.com dashboard) ---
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_SIGNING_SECRET=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_PRODUCT_ID=

# Public URL of the deployed app (used in checkout redirect)
APP_URL=
